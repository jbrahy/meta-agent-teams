# .agent-teams.env — Local provider configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .agent-teams.env and fill in your settings.
# .agent-teams.env is gitignored — never commit it.
#
# Settings here override agent.yaml values for the current environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Provider ──────────────────────────────────────────────────────────────────
# Which LLM backend to use. Options:
#
#   claude   Anthropic Claude Code CLI (default — no API key needed if installed)
#   llm      Simon Willison's multi-provider llm tool (pip install llm)
#   ollama   Local models via Ollama (https://ollama.ai)
#   openai   OpenAI-compatible API via curl + jq
#
# AGENT_PROVIDER=claude

# ── Model ─────────────────────────────────────────────────────────────────────
# Override the model defined in each agent.yaml.
# Leave unset to use per-agent model settings from agent.yaml.
#
# Claude:   claude-sonnet-4-5, claude-haiku-4-5-20251001, claude-opus-4-6
# OpenAI:   gpt-4o, gpt-4o-mini, o1-preview
# Ollama:   llama3.2, mistral, codellama, qwen2.5
# llm:      claude-3.5-sonnet (anthropic plugin), gpt-4o (openai), etc.
#
# AGENT_MODEL=

# ── OpenAI / OpenAI-compatible API ────────────────────────────────────────────
# Required when AGENT_PROVIDER=openai.
# Also works with local OpenAI-compatible servers.
#
# OPENAI_API_KEY=sk-...
# AGENT_API_BASE=https://api.openai.com/v1
# AGENT_MODEL=gpt-4o

# ── Example configurations ────────────────────────────────────────────────────

# Use Ollama with llama3.2 (fully local, no API key):
#   AGENT_PROVIDER=ollama
#   AGENT_MODEL=llama3.2

# Use the llm tool with Anthropic (requires: pip install llm llm-claude-3):
#   AGENT_PROVIDER=llm
#   AGENT_MODEL=claude-3.5-sonnet

# Use the llm tool with Ollama (requires: pip install llm llm-ollama):
#   AGENT_PROVIDER=llm
#   AGENT_MODEL=llama3.2:latest

# Use LM Studio or vLLM (local OpenAI-compatible server):
#   AGENT_PROVIDER=openai
#   AGENT_API_BASE=http://localhost:1234/v1
#   OPENAI_API_KEY=not-needed
#   AGENT_MODEL=local-model

# Use Azure OpenAI:
#   AGENT_PROVIDER=openai
#   AGENT_API_BASE=https://YOUR_RESOURCE.openai.azure.com/openai/deployments/YOUR_DEPLOY
#   OPENAI_API_KEY=your-azure-key
#   AGENT_MODEL=gpt-4o
